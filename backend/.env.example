# Copy to .env for local overrides (not committed).
# On Render, set these in the web service Environment tab.

# Comma-separated browser origins allowed to call the API (include your Vercel URL in production).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Set true only for quick throwaway demos — disables origin restrictions (not recommended).
DEMO_ALLOW_ALL_CORS=false

# Optional: override SQLite path (Render ephemeral disk is fine for hackathon demo).
# BIOVAULT_DB=/var/data/biovault.db
